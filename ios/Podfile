platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

# --- DYNAMIC FLUTTER PATH FIX ---
# Checks Codemagic environment variable first, then falls back to local path
flutter_root = ENV['FLUTTER_ROOT'] || File.expand_path(File.join('..', '..', 'flutter'), __FILE__)
if !File.directory?(flutter_root)
  # Fallback to standard local relative path just in case
  flutter_root = File.expand_path(File.join('..', 'flutter'), __FILE__)
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)
# --------------------------------

# --- PHANTOM TARGET FIX ---
pre_install do |installer|
  sandbox_project = installer.aggregate_targets.first.user_project
  test_target = sandbox_project.targets.find { |t| t.name == 'RunnerTests' }
  if test_target
    puts "Codemagic Fix: Removing phantom RunnerTests target to prevent build crash."
    test_target.remove_from_project
  end
end
# --------------------------

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods(File.dirname(File.realpath(__FILE__)))
end

post_install do |installer|
  flutter_post_install(installer)
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end